# ══════════════════════════════════════════════════════════════════════════════
# ScholarNode AI  ·  .gitignore
# ══════════════════════════════════════════════════════════════════════════════

# ── Python ─────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo

# ── Virtual environments ────────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.python-version

# ── Environment / Secrets (NEVER commit these) ─────────────────────────────────
.env
.env.*
!.env.example

# ── Runtime data (generated at runtime — excluded for repo cleanliness) ─────────
data/*
!data/.gitkeep

# ── SQLite databases ────────────────────────────────────────────────────────────
*.db
*.sqlite3

# ── ChromaDB vector store (generated per session) ──────────────────────────────
data/chroma/
data/evidence_store/

# ── Exported reports (generated output, not source) ────────────────────────────
exports/*
!exports/.gitkeep

# ── DB migrations / runtime files ──────────────────────────────────────────────
db/*.db
db/*.sqlite3

# ── Logs ───────────────────────────────────────────────────────────────────────
*.log
*.out
*.err
logs/

# ── ML / model weights ─────────────────────────────────────────────────────────
*.h5
*.pt
*.pth
*.ckpt
*.onnx
*.pkl
*.joblib
*.bin

# ── Frontend ───────────────────────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/.eslintcache

# ── OS artifacts ───────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Editor / IDE ───────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.suo
*.user
*.sublime-workspace

# ── Cache & temp ───────────────────────────────────────────────────────────────
.cache/
*.tmp
*.temp
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── Jupyter ────────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Docker ─────────────────────────────────────────────────────────────────────
# (Dockerfile and .dockerignore ARE tracked)

# ── Test artifacts ─────────────────────────────────────────────────────────────
htmlcov/
.coverage
coverage.xml